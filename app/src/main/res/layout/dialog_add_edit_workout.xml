<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="#F7FAF8">

        <!-- ══ Header ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">



            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"

                android:textSize="12sp"
                android:textColor="#7A9E8A"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- ══ Card thông tin cơ bản ══ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <!-- Section label -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">

                    <View
                        android:layout_width="3dp"
                        android:layout_height="18dp"
                        android:background="#1A6B43"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thông tin bài tập"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#0F2D1F" />
                </LinearLayout>

                <!-- Tên bài tập -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tên bài tập *"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#3D6B52"
                    android:layout_marginBottom="5dp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/bg_input_field">

                    <EditText
                        android:id="@+id/etWorkoutName"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="0dp"
                        android:hint="Ví dụ: Chạy bộ nhẹ nhàng"
                        android:textColorHint="#BBCCC5"
                        android:textColor="#0F2D1F"
                        android:textSize="14sp"
                        android:inputType="text"
                        android:background="@null"
                        android:gravity="center_vertical" />
                </FrameLayout>

                <!-- Mô tả -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mô tả"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#3D6B52"
                    android:layout_marginBottom="5dp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/bg_input_field"
                    android:minHeight="80dp">

                    <EditText
                        android:id="@+id/etWorkoutDesc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="14dp"
                        android:hint="Mô tả ngắn về bài tập..."
                        android:textColorHint="#BBCCC5"
                        android:textColor="#0F2D1F"
                        android:textSize="13sp"
                        android:inputType="textMultiLine"
                        android:minLines="2"
                        android:maxLines="3"
                        android:background="@null"
                        android:gravity="top" />
                </FrameLayout>

                <!-- Nhóm BMI + Độ khó side by side -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nhóm BMI"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="#3D6B52"
                            android:layout_marginBottom="5dp" />

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_input_field">

                            <Spinner
                                android:id="@+id/spinnerBmiCategory"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:paddingHorizontal="10dp"
                                android:background="@null" />
                        </FrameLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Độ khó"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="#3D6B52"
                            android:layout_marginBottom="5dp" />

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_input_field">

                            <Spinner
                                android:id="@+id/spinnerLevel"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:paddingHorizontal="10dp"
                                android:background="@null" />
                        </FrameLayout>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══ Card số liệu ══ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <!-- Section label -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">

                    <View
                        android:layout_width="3dp"
                        android:layout_height="18dp"
                        android:background="#1A6B43"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Số liệu &amp; video"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#0F2D1F" />
                </LinearLayout>

                <!-- Thời gian + Calories -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="14dp">

                    <!-- Thời gian -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Thời gian (phút)"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="#3D6B52"
                            android:layout_marginBottom="5dp" />

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_input_field">

                            <EditText
                                android:id="@+id/etDuration"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:paddingHorizontal="14dp"
                                android:paddingVertical="0dp"
                                android:hint="30"
                                android:textColorHint="#BBCCC5"
                                android:textColor="#0F2D1F"
                                android:textSize="14sp"
                                android:inputType="number"
                                android:background="@null"
                                android:gravity="center_vertical" />
                        </FrameLayout>
                    </LinearLayout>

                    <!-- Calories -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Calories (kcal)"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="#3D6B52"
                            android:layout_marginBottom="5dp" />

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_input_field">

                            <EditText
                                android:id="@+id/etCalories"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:paddingHorizontal="14dp"
                                android:paddingVertical="0dp"
                                android:hint="200"
                                android:textColorHint="#BBCCC5"
                                android:textColor="#0F2D1F"
                                android:textSize="14sp"
                                android:inputType="number"
                                android:background="@null"
                                android:gravity="center_vertical" />
                        </FrameLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Link video -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Link video (tùy chọn)"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#3D6B52"
                    android:layout_marginBottom="5dp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_input_field">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="start|center_vertical"
                        android:layout_marginStart="12dp"
                        android:src="@drawable/ic_link"
                        android:alpha="0.4" />

                    <EditText
                        android:id="@+id/etVideoUrl"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingStart="38dp"
                        android:paddingEnd="14dp"
                        android:paddingVertical="0dp"
                        android:hint="https://youtube.com/..."
                        android:textColorHint="#BBCCC5"
                        android:textColor="#0F2D1F"
                        android:textSize="13sp"
                        android:inputType="textUri"
                        android:background="@null"
                        android:gravity="center_vertical" />
                </FrameLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>



    </LinearLayout>
</ScrollView>