<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="8dp"
        android:paddingBottom="24dp"
        android:background="#F7FAF8">

        <!-- ══ Header ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="16dp"
            android:paddingBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Điền thông tin để bắt đầu"
                android:textSize="13sp"
                android:textColor="#7A9E8A"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- ══ Card chính ══ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Họ tên -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Họ và tên"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#3D6B52"
                    android:layout_marginBottom="6dp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_input_field">

                    <EditText
                        android:id="@+id/etName"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="0dp"
                        android:hint="Nguyễn Văn A"
                        android:textColorHint="#BBCCC5"
                        android:textColor="#0F2D1F"
                        android:textSize="14sp"
                        android:inputType="textPersonName"
                        android:background="@null"
                        android:gravity="center_vertical" />
                </FrameLayout>

                <!-- Email -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#3D6B52"
                    android:layout_marginBottom="6dp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_input_field">

                    <EditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="0dp"
                        android:hint="example@email.com"
                        android:textColorHint="#BBCCC5"
                        android:textColor="#0F2D1F"
                        android:textSize="14sp"
                        android:inputType="textEmailAddress"
                        android:background="@null"
                        android:gravity="center_vertical" />
                </FrameLayout>

                <!-- Giới tính -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Giới tính"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#3D6B52"
                    android:layout_marginBottom="6dp" />

                <RadioGroup
                    android:id="@+id/rgGender"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/rbMale"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="👨  Nam"
                        android:textSize="13sp"
                        android:textColor="#0F2D1F"
                        android:background="@drawable/bg_radio_selector"
                        android:gravity="center"
                        android:button="@null"
                        android:layout_marginEnd="6dp"
                        android:checked="true" />

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/rbFemale"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="👩  Nữ"
                        android:textSize="13sp"
                        android:textColor="#0F2D1F"
                        android:background="@drawable/bg_radio_selector"
                        android:gravity="center"
                        android:button="@null"
                        android:layout_marginStart="6dp" />
                </RadioGroup>

                <!-- Ngày sinh -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ngày sinh"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#3D6B52"
                    android:layout_marginBottom="6dp" />

                <FrameLayout
                    android:id="@+id/layoutDob"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_input_field"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/tvDob"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="14dp"
                        android:text="Chọn ngày sinh"
                        android:textColor="#BBCCC5"
                        android:textSize="14sp" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="14dp"
                        android:src="@drawable/ic_calendar"
                        android:alpha="0.4" />
                </FrameLayout>

                <!-- Chiều cao / Cân nặng -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Chiều cao (cm)"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#3D6B52"
                            android:layout_marginBottom="6dp" />

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:background="@drawable/bg_input_field">

                            <EditText
                                android:id="@+id/etHeight"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:paddingHorizontal="14dp"
                                android:paddingVertical="0dp"
                                android:hint="170"
                                android:textColorHint="#BBCCC5"
                                android:textColor="#0F2D1F"
                                android:textSize="14sp"
                                android:inputType="numberDecimal"
                                android:background="@null"
                                android:gravity="center_vertical" />
                        </FrameLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cân nặng (kg)"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#3D6B52"
                            android:layout_marginBottom="6dp" />

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:background="@drawable/bg_input_field">

                            <EditText
                                android:id="@+id/etWeight"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:paddingHorizontal="14dp"
                                android:paddingVertical="0dp"
                                android:hint="60"
                                android:textColorHint="#BBCCC5"
                                android:textColor="#0F2D1F"
                                android:textSize="14sp"
                                android:inputType="numberDecimal"
                                android:background="@null"
                                android:gravity="center_vertical" />
                        </FrameLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Mật khẩu -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mật khẩu"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#3D6B52"
                    android:layout_marginBottom="6dp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_input_field">

                    <EditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingStart="14dp"
                        android:paddingEnd="48dp"
                        android:paddingVertical="0dp"
                        android:hint="Tối thiểu 6 ký tự"
                        android:textColorHint="#BBCCC5"
                        android:textColor="#0F2D1F"
                        android:textSize="14sp"
                        android:inputType="textPassword"
                        android:background="@null"
                        android:gravity="center_vertical" />

                    <ImageView
                        android:id="@+id/ivTogglePassword"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="14dp"
                        android:src="@drawable/ic_eye_off"
                        android:alpha="0.45"
                        android:clickable="true"
                        android:focusable="true" />
                </FrameLayout>

                <!-- ══ VAI TRÒ (PHÂN QUYỀN) ══ -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vai trò"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#3D6B52"
                    android:layout_marginBottom="6dp" />

                <RadioGroup
                    android:id="@+id/rgVaiTro"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/rbUser"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="👤  User"
                        android:textSize="13sp"
                        android:textColor="#0F2D1F"
                        android:background="@drawable/bg_radio_selector"
                        android:gravity="center"
                        android:button="@null"
                        android:layout_marginEnd="6dp"
                        android:checked="true" />

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/rbAdmin"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="🛡️  Admin"
                        android:textSize="13sp"
                        android:textColor="#0F2D1F"
                        android:background="@drawable/bg_radio_selector"
                        android:gravity="center"
                        android:button="@null"
                        android:layout_marginStart="6dp" />
                </RadioGroup>

                <!-- Note bắt buộc -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="* Tất cả các trường đều bắt buộc"
                    android:textColor="#E53935"
                    android:textSize="11sp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>