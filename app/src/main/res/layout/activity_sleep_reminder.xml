<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#9CB7FF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- ===== HEADER ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#001128"
            android:orientation="vertical"
            android:paddingTop="16dp"
            android:paddingBottom="28dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_back"
                android:background="@drawable/bg_circle_white_alpha"
                android:padding="8dp"
                />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌙 Nhắc Đi Ngủ"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Giấc ngủ đủ giấc là nền tảng của sức khoẻ"
                android:textSize="13sp"
                android:textColor="#8BA7C7"
                android:layout_marginTop="4dp" />

            <!-- Big clock display -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="😴 NGỦ LÚC"
                        android:textSize="11sp"
                        android:textColor="#8BA7C7"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/tvSleepTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="22:00"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="→"
                    android:textSize="20sp"
                    android:textColor="#4A6FA5"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="☀️ THỨC LÚC"
                        android:textSize="11sp"
                        android:textColor="#8BA7C7"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/tvWakeUpTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--:--"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        android:textColor="#A8C8E8"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ===== CONTENT AREA ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- === CARD 1: Thời lượng ngủ === -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#1A2B3C"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⏳ Thời Lượng Ngủ"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#A8C8E8" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Khuyến nghị: 7 – 9 tiếng mỗi đêm"
                        android:textSize="12sp"
                        android:textColor="#5A7A9A"
                        android:layout_marginTop="2dp" />

                    <EditText
                        android:id="@+id/etSleepHours"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="Bạn muốn ngủ mấy tiếng? (VD: 8)"
                        android:inputType="numberDecimal"
                        android:layout_marginTop="12dp"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:background="#0D1B2A"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#4A6A8A"
                        android:textSize="14sp" />

                    <!-- Quick Duration Chips -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚡ Chọn nhanh:"
                        android:textSize="12sp"
                        android:textColor="#5A7A9A"
                        android:layout_marginTop="10dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="6dp">

                        <Button
                            android:id="@+id/btn6h"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:text="6 tiếng"
                            android:textSize="11sp"
                            android:textColor="#A8C8E8"
                            android:backgroundTint="#1E3550"
                            android:layout_marginEnd="6dp"
                            app:cornerRadius="8dp" />

                        <Button
                            android:id="@+id/btn7h"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:text="7 tiếng"
                            android:textSize="11sp"
                            android:textColor="#A8C8E8"
                            android:backgroundTint="#1E3550"
                            android:layout_marginEnd="6dp"
                            app:cornerRadius="8dp" />

                        <Button
                            android:id="@+id/btn8h"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:text="8 tiếng"
                            android:textSize="11sp"
                            android:textColor="#FFFFFF"
                            android:backgroundTint="#2A5298"
                            android:layout_marginEnd="6dp"
                            app:cornerRadius="8dp" />

                        <Button
                            android:id="@+id/btn9h"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:text="9 tiếng"
                            android:textSize="11sp"
                            android:textColor="#A8C8E8"
                            android:backgroundTint="#1E3550"
                            app:cornerRadius="8dp" />
                    </LinearLayout>

                    <!-- Duration warning -->
                    <TextView
                        android:id="@+id/tvDurationWarning"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.4"
                        android:layout_marginTop="12dp"
                        android:padding="12dp"
                        android:textColor="#FFB74D"
                        android:background="#2A1E00" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- === CARD 2: Giờ đi ngủ === -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#1A2B3C"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🕙 Giờ Đi Ngủ"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#A8C8E8" />

                    <TextView
                        android:id="@+id/tvLeadTimeLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🔔 Nhắc trước bao nhiêu phút?"
                        android:textSize="12sp"
                        android:textColor="#5A7A9A"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="10dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">

                        <Button
                            android:id="@+id/btnLead15"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:text="15 phút"
                            android:textSize="11sp"
                            android:textColor="#A8C8E8"
                            android:backgroundTint="#1E3550"
                            android:layout_marginEnd="6dp"
                            app:cornerRadius="8dp" />

                        <Button
                            android:id="@+id/btnLead30"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:text="30 phút"
                            android:textSize="11sp"
                            android:textColor="#FFFFFF"
                            android:backgroundTint="#2A5298"
                            android:layout_marginEnd="6dp"
                            app:cornerRadius="8dp" />

                        <Button
                            android:id="@+id/btnLead45"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:text="45 phút"
                            android:textSize="11sp"
                            android:textColor="#A8C8E8"
                            android:backgroundTint="#1E3550"
                            android:layout_marginEnd="6dp"
                            app:cornerRadius="8dp" />

                        <Button
                            android:id="@+id/btnLead60"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:text="60 phút"
                            android:textSize="11sp"
                            android:textColor="#A8C8E8"
                            android:backgroundTint="#1E3550"
                            app:cornerRadius="8dp" />
                    </LinearLayout>



                    <!-- Time Picker Button + Display -->
                    <Button
                        android:id="@+id/btnPickSleepTime"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="⏰ Chọn giờ đi ngủ"
                        android:textSize="14sp"
                        android:textColor="#A8C8E8"
                        android:backgroundTint="#1E3550"
                        app:cornerRadius="12dp"
                        android:layout_marginTop="12dp" />

                    <!-- Quick bedtime suggestions -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚡ Gợi ý giờ ngủ:"
                        android:textSize="12sp"
                        android:textColor="#5A7A9A"
                        android:layout_marginTop="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="6dp">

                        <Button
                            android:id="@+id/btnSleep21"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:text="21:00"
                            android:textSize="11sp"
                            android:textColor="#A8C8E8"
                            android:backgroundTint="#1E3550"
                            android:layout_marginEnd="6dp"
                            app:cornerRadius="8dp" />

                        <Button
                            android:id="@+id/btnSleep2130"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:text="21:30"
                            android:textSize="11sp"
                            android:textColor="#A8C8E8"
                            android:backgroundTint="#1E3550"
                            android:layout_marginEnd="6dp"
                            app:cornerRadius="8dp" />

                        <Button
                            android:id="@+id/btnSleep22"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:text="22:00"
                            android:textSize="11sp"
                            android:textColor="#FFFFFF"
                            android:backgroundTint="#2A5298"
                            android:layout_marginEnd="6dp"
                            app:cornerRadius="8dp" />

                        <Button
                            android:id="@+id/btnSleep2230"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:text="22:30"
                            android:textSize="11sp"
                            android:textColor="#A8C8E8"
                            android:backgroundTint="#1E3550"
                            app:cornerRadius="8dp" />
                    </LinearLayout>

                    <!-- Time warning / suggestion -->
                    <TextView
                        android:id="@+id/tvTimeSuggestion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.4"
                        android:layout_marginTop="12dp"
                        android:padding="12dp"
                        android:textColor="#80CBC4"
                        android:background="#0D2622" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- === CARD 3: Lời khuyên giấc ngủ === -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardAdvice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#1A2B3C"
                android:layout_marginBottom="20dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📋 Phân Tích Giấc Ngủ"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#A8C8E8" />

                    <TextView
                        android:id="@+id/tvSleepAdvice"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#8AADCC"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.7"
                        android:layout_marginTop="10dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- === ACTION BUTTONS === -->
            <Button
                android:id="@+id/btnSetSleepReminder"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="🌙  Đặt Nhắc Đi Ngủ"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="#2A5298"
                android:textColor="#FFFFFF"
                app:cornerRadius="16dp"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btnCancelReminder"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="🚫  Hủy Nhắc Nhở"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="#2A1A1A"
                android:textColor="#EF9A9A"
                app:cornerRadius="16dp" />

            <TextView
                android:id="@+id/tvReminderStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:textColor="#5A7A9A"
                android:gravity="center"
                android:layout_marginTop="12dp" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>