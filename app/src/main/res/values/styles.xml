<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="LabelStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#0F2D1F</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:layout_marginBottom">4dp</item>
        <item name="android:layout_marginTop">4dp</item>
    </style>
    <style name="DatePickerTheme" parent="Theme.AppCompat.Light.Dialog">
        <item name="colorAccent">#1A6B3C</item>
        <item name="android:textColorPrimary">#0F2D1F</item>
    </style>
    <style name="GreenDatePickerDialog" parent="Theme.AppCompat.Light.Dialog">
        <item name="colorPrimary">#15803D</item>
        <item name="colorPrimaryDark">#166534</item>
        <item name="colorAccent">#22C55E</item>
        <item name="android:textColorPrimary">#0F172A</item>
        <item name="android:background">#FFFFFF</item>
    </style>
    <style name="FieldBox">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">14dp</item>
        <item name="android:background">@drawable/bg_field_box</item>
    </style>

    <style name="FieldEdit">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@null</item>
        <item name="android:padding">14dp</item>
        <item name="android:textColor">#0F2D1F</item>
        <item name="android:textColorHint">#AAAAAA</item>
        <item name="android:textSize">14sp</item>
    </style>
</resources>